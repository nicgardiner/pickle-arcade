rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /lobbies/{lobbyId} {
      allow read:   if true;
      allow create: if request.auth != null;

      // The heartbeat-only guard belongs on UPDATE (it compares the doc before
      // and after a write). It was previously attached to `delete`, where
      // request.resource doesn't exist — the condition errored, so EVERY
      // delete was denied and closed rooms lived forever as ghosts. There was
      // also no update rule at all, so heartbeat PATCHes were denied and live
      // rooms vanished from browsers ~2 minutes after being created.
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['heartbeat']);

      // Any signed-in player may delete a lobby doc. This has to stay open
      // (not owner-only) for two reasons: hosts sign in anonymously and get a
      // NEW uid every session, so even a host can't match its own old docs;
      // and the SDK design has *readers* prune rooms whose heartbeat is >10
      // minutes stale, which is inherently a cross-user delete.
      allow delete: if request.auth != null;
    }

    match /feedback/{doc} {
      allow create: if request.auth != null;
      allow read, delete: if request.auth != null
        && request.auth.uid == 'ueZpcTUtabV7BcUzjiwbZ4NTLne2';
      allow update: if (request.auth != null
                        && request.auth.uid == 'ueZpcTUtabV7BcUzjiwbZ4NTLne2')
                    || (request.auth != null && doc == 'user_' + request.auth.uid);
    }
  }
}
