{
  "name": "pickle-arcade",
  "productName": "Pickle Arcade",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.pickle.arcade",
    "productName": "Pickle Arcade",
    "win": {
      "target": "nsis"
    },
    "publish": {
      "provider": "github",
      "owner": "nicgardiner",
      "repo": "pickle-arcade"
    },
    "files": [
      "**/*",
      "!dist/**",
      "!.git/**"
    ]
  },
  "devDependencies": {
    "electron": "^35.7.5",
    "electron-builder": "^26.15.3"
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "firebase": "^12.14.0"
  }
}
